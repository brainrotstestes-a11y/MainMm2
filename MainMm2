local esp = false
local highlights = {}

local function createESP(p,color)
	if p ~= player then
		local function apply(char)
			local h = Instance.new("Highlight")
			h.FillColor = color
			h.OutlineColor = color
			h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			h.Parent = char
			table.insert(highlights,h)
		end
		if p.Character then
			apply(p.Character)
		end
		p.CharacterAdded:Connect(apply)
	end
end

local function clearESP()
	for _,v in pairs(highlights) do
		if v then
			v:Destroy()
		end
	end
	highlights = {}
end

espButton.MouseButton1Click:Connect(function()
	esp = not esp
	if esp then
		espButton.Text = "ESP ON"
		espButton.BackgroundColor3 = Color3.fromRGB(0,120,0)

		for _,p in pairs(Players:GetPlayers()) do
			local role = ""
			if p:FindFirstChild("Role") then
				role = p.Role.Value
			end

			if role == "Assassino" or role == "Murder" then
				createESP(p,Color3.fromRGB(255,0,0))
			elseif role == "Policia" or role == "Police" then
				createESP(p,Color3.fromRGB(0,0,255))
			else
				createESP(p,Color3.fromRGB(0,255,0))
			end
		end

	else
		espButton.Text = "ESP OFF"
		espButton.BackgroundColor3 = Color3.fromRGB(80,0,0)
		clearESP()
	end
end)
